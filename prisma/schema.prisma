// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  priority    Priority @default(MEDIUM)
  status      Status   @default(BACKLOG)
  assignee    String
  tag         String?
  
  // Approval workflow fields
  requiresApproval Boolean  @default(false)
  approvedBy       String?
  rejectedBy       String?
  rejectionReason  String?  @db.Text
  approvedAt       DateTime?
  rejectedAt       DateTime?
  
  // Task management
  deadline         DateTime?
  
  // Timestamps
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  
  // Relations
  comments         Comment[]
  
  @@index([assignee])
  @@index([status])
  @@index([requiresApproval])
  @@index([createdAt])
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  author    String
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  
  @@index([taskId])
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

enum Status {
  BACKLOG
  IN_PROGRESS
  REVIEW
  DONE
}

model ActivityEvent {
  id        String   @id @default(cuid())
  agent     String   // Which agent performed the action
  action    String   // What they did (e.g., "deployment", "task_completed", "status_change")
  metadata  Json?    // Additional context about the action
  timestamp DateTime @default(now())
  
  @@index([timestamp])
  @@index([agent])
}

model ActiveWork {
  id        String   @id @default(cuid())
  agent     String
  task      String
  status    String   // "running", "blocked", "paused"
  progress  Int      @default(0) // 0-100
  metadata  Json?
  startedAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([agent])
  @@index([status])
}

model CalendarEvent {
  id             String            @id @default(cuid())
  title          String
  description    String?
  type           CalendarEventType @default(TASK_EVENT)
  startTime      DateTime
  endTime        DateTime?
  taskId         String?
  isRecurring    Boolean           @default(false)
  recurrenceRule String?          // RRULE format
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([startTime])
  @@index([taskId])
}

enum CalendarEventType {
  TASK_EVENT
  MEETING
  RECURRING
}

model Event {
  id         String   @id @default(cuid())
  type       String   // "session_created", "session_activity", "tool_call", etc.
  sessionKey String?  // OpenClaw session key
  timestamp  DateTime
  data       Json     // Event-specific data
  createdAt  DateTime @default(now())
  
  @@index([type])
  @@index([timestamp])
  @@index([sessionKey])
}
